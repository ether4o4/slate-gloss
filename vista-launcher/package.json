{
  "name": "vistalauncher",
  "version": "1.0.0",
  "description": "VistaLauncher - A Windows Vista-style React Native launcher",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "build": "./build-apk.sh",
    "build:release": "./build-apk.sh release",
    "build:debug": "./build-apk.sh debug",
    "clean": "cd android && ./gradlew clean",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-community/blur": "^4.4.1",
    "@shopify/react-native-skia": "^1.11.18",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^4.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.0",
    "@react-native/eslint-config": "0.73.0",
    "@react-native/metro-config": "0.73.0",
    "@react-native/typescript-config": "0.73.0",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
